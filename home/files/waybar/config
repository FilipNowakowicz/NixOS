{
    "layer": "top",
    "position": "top",
    "height": 48,
    "margin-top": 6,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 4,

    "modules-left":   ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right":  ["group/tray-group", "bluetooth", "network", "pulseaudio", "battery"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active":  "●",
            "default": "●",
            "empty":   "○"
        },
        "persistent-workspaces": {
            "*": 10
        },
        "on-click": "activate",
        "sort-by-number": true
    },

    "clock": {
        "interval": 60,
        "format": "{:%H:%M <span alpha='9999'> · %a %d</span>}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "group/tray-group": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "children-class": "tray-child",
            "transition-left-to-right": false
        },
        "modules": ["custom/chevron", "tray"]
    },

    "custom/chevron": {
        "format": "‹",
        "tooltip": false
    },

    "tray": {
        "icon-size": 14,
        "spacing":   6
    },

    "battery": {
        "format":          "{icon}  {capacity}%",
        "format-charging": "󰂄  {capacity}%",
        "format-full":     "󰁹",
        "format-icons":    ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "states": {
            "warning":  30,
            "critical": 15
        }
    },

    "pulseaudio": {
        "format":       "{icon}",
        "format-muted": "󰝟",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click":    "pavucontrol",
        "scroll-step": 5
    },

    "network": {
        "format-wifi":        "{icon}",
        "format-ethernet":    "󰈀",
        "format-disconnected": "󰤭",
        "format-icons":       ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
        "tooltip-format":             "{essid} {signalStrength}%",
        "tooltip-format-disconnected": "Disconnected"
    },

    "bluetooth": {
        "format":           "󰂯",
        "format-connected": "󰂱  {device_alias}",
        "format-off":       "󰂲",
        "tooltip-format":   "{controller_alias}\t{controller_address}",
        "on-click":         "blueman-manager"
    }
}
