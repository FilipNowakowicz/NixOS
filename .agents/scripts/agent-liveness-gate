#!/usr/bin/env bash
# Deterministic liveness gate for scripts/agent-run-issue.sh cold-start
# prerequisites.
#
# Checks that the local commands the issue-runner needs are on PATH, that
# `gh` is authenticated, and that the cheap/deterministic self-tests of the
# agent workflow scripts it relies on (readiness lint, outcome recording,
# outcome index) all pass. Does not perform live agent dispatch.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: agent-liveness-gate [--skip-gh-auth]
       agent-liveness-gate --self-test

Checks the cold-start prerequisites scripts/agent-run-issue.sh needs before a
batch of issues is dispatched:

  - required local commands are on PATH (git, gh, jq, claude)
  - "gh auth status" succeeds (skip with --skip-gh-auth)
  - the cheap, deterministic self-tests of the agent workflow scripts it
    depends on for readiness checks and outcome recording all pass

This does not perform live agent dispatch, and beyond "gh auth status" itself
does not require secrets, sudo, deployment access, or remote host access.

Options:
  --skip-gh-auth   Skip the "gh auth status" check (e.g. before the scoped
                    PAT is provisioned on a fresh host).
  --self-test      Run a local smoke test against fixtures and exit.
  -h, --help       Show this help.
EOF
}

die() {
  printf 'agent-liveness-gate: %s\n' "$*" >&2
  exit 1
}

script_dir() {
  cd "$(dirname "${BASH_SOURCE[0]}")" && pwd
}

# Required commands for the issue-runner cold start: claude/gh/git mirror the
# checks in scripts/agent-run-issue.sh, jq is needed by outcome recording and
# discovery (.agents/scripts/agent-record-outcome, agent-outcome-index).
required_commands=(git gh jq claude)

# Cheap, deterministic self-tests of the agent workflow scripts the runner
# depends on for readiness gating and outcome recording.
self_test_targets=(
  agent-issue-readiness
  agent-record-outcome
  agent-outcome-index
)

# Verify each given command is on PATH.
check_commands() {
  local missing=() cmd
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    printf 'agent-liveness-gate: missing required command(s): %s\n' "${missing[*]}" >&2
    return 1
  fi
  printf 'agent-liveness-gate: required commands present: %s\n' "$*"
}

check_gh_auth() {
  if ! command -v gh >/dev/null 2>&1; then
    printf 'agent-liveness-gate: gh not found; cannot check gh auth status\n' >&2
    return 1
  fi
  if ! gh auth status >/dev/null 2>&1; then
    printf 'agent-liveness-gate: gh is not authenticated (run "gh auth login", or provision the scoped PAT - hosts/gcp-agent/CLAUDE.md)\n' >&2
    return 1
  fi
  printf 'agent-liveness-gate: gh auth OK\n'
}

# Run "<dir>/<name> --self-test" for each remaining argument, reporting
# pass/fail per target.
run_self_tests() {
  local dir=$1
  shift
  local failed=0 name path
  for name in "$@"; do
    path="$dir/$name"
    if [[ ! -x $path ]]; then
      printf 'agent-liveness-gate: self-test target not found or not executable: %s\n' "$path" >&2
      failed=1
      continue
    fi
    if "$path" --self-test >/dev/null 2>&1; then
      printf 'agent-liveness-gate: %s --self-test: passed\n' "$name"
    else
      printf 'agent-liveness-gate: %s --self-test: FAILED\n' "$name" >&2
      failed=1
    fi
  done
  return "$failed"
}

self_test() {
  local tmp out
  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' RETURN

  # check_commands: a present command passes ...
  check_commands bash >/dev/null ||
    die "self-test: expected a present command to pass check_commands"

  # ... and a missing command fails, naming the missing command.
  if out=$(check_commands bash __agent_liveness_gate_missing_cmd__ 2>&1); then
    die "self-test: expected a missing command to fail check_commands"
  fi
  [[ $out == *"__agent_liveness_gate_missing_cmd__"* ]] ||
    die "self-test: expected missing-command message to name the missing command (got: $out)"

  # run_self_tests: passing and failing fixture targets.
  cat >"$tmp/agent-pass" <<'FIXTURE'
#!/usr/bin/env bash
[[ "${1:-}" == --self-test ]] || exit 2
exit 0
FIXTURE
  cat >"$tmp/agent-fail" <<'FIXTURE'
#!/usr/bin/env bash
[[ "${1:-}" == --self-test ]] || exit 2
exit 1
FIXTURE
  chmod +x "$tmp/agent-pass" "$tmp/agent-fail"

  run_self_tests "$tmp" agent-pass >/dev/null ||
    die "self-test: expected a passing self-test target to succeed"

  if out=$(run_self_tests "$tmp" agent-pass agent-fail 2>&1); then
    die "self-test: expected a failing self-test target to fail the gate"
  fi
  [[ $out == *"agent-fail --self-test: FAILED"* ]] ||
    die "self-test: expected failure message to name the failing target (got: $out)"

  if out=$(run_self_tests "$tmp" agent-missing 2>&1); then
    die "self-test: expected a missing self-test target to fail the gate"
  fi
  [[ $out == *"not found"* ]] ||
    die "self-test: expected a missing-target message (got: $out)"

  printf 'agent-liveness-gate self-test passed\n'
}

main() {
  local skip_gh_auth=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --skip-gh-auth)
      skip_gh_auth=1
      shift
      ;;
    --self-test)
      self_test
      exit 0
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
    esac
  done

  local dir failed=0
  dir="$(script_dir)"

  check_commands "${required_commands[@]}" || failed=1

  if [[ $skip_gh_auth == 1 ]]; then
    echo "agent-liveness-gate: skipping gh auth check (--skip-gh-auth)"
  else
    check_gh_auth || failed=1
  fi

  run_self_tests "$dir" "${self_test_targets[@]}" || failed=1

  if [[ $failed -eq 0 ]]; then
    echo "agent-liveness-gate: ready"
    return 0
  fi
  echo "agent-liveness-gate: NOT READY (see failures above)" >&2
  return 1
}

main "$@"
