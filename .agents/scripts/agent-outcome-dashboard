#!/usr/bin/env bash
# Render a deterministic Markdown "outcome dashboard" from committed
# agent-outcome/v1 records (see .agents/schemas/outcome.schema.json).
#
# Presentation only: this script never touches live infrastructure, never
# adds telemetry fields, and never mutates the outcome records. It reads the
# same JSON files as .agents/scripts/agent-outcome-index and turns them into a
# single at-a-glance Markdown report:
#
#   - a per-run table (issue, status, cost_usd, turns, duration, risk),
#   - aggregate totals (runs, status mix, total/avg cost, turns, duration),
#   - a cost/turns trend over time (one row per run, oldest first), and
#   - a breakdown of failure blockers (status=failure, grouped by reason).
#
# Output is reproducible: records are sorted by (started_at, id) so the same
# input directory always yields byte-identical Markdown. Records without a
# .session object (older or pre-dispatch runs) are surfaced with em dashes
# rather than crashing.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: agent-outcome-dashboard [--dir <path>] [--out <path>]
       agent-outcome-dashboard --self-test

Reads agent-outcome/v1 records from --dir (default: .agents/state/outcomes,
or $AGENT_OUTCOME_DIR) using the same validity check as
.agents/scripts/agent-outcome-index, and prints a Markdown dashboard to
stdout (or to --out <path> if given).

The dashboard contains:

  - Per-run table: issue, status, cost_usd, turns, duration, route risk.
  - Aggregate totals: run count, status mix, total/average cost_usd, total
    turns, total duration.
  - Cost / turns trend: one row per run in chronological order so cost and
    turn growth over time is visible at a glance.
  - Failure blockers: status=failure records grouped by blocker reason.

Records are sorted by (started_at, id), so output is byte-stable for a given
input directory. Records with no .session object are shown with "—" in the
cost/turns/duration columns instead of failing.

Options:
  --dir <path>   Outcome directory to scan (default: .agents/state/outcomes,
                  or $AGENT_OUTCOME_DIR if set).
  --out <path>   Write the report to <path> instead of stdout.
  --self-test    Run a deterministic self-test against tmp-dir fixtures and
                  exit (no live records, GitHub, or model calls).
  -h, --help     Show this help.

This generator is presentation-only: it never files issues, posts comments,
merges PRs, mutates outcome records, or adds telemetry fields.
EOF
}

die() {
  printf 'agent-outcome-dashboard: %s\n' "$*" >&2
  exit 1
}

# Read valid agent-outcome/v1 records from $1 and emit one compact JSON object
# per line, sorted by (started_at, id). Mirrors agent-outcome-index's validity
# check, but keeps the whole record so .session and .route stay available.
# Malformed or schema-mismatched files are skipped silently (presentation
# tool; agent-outcome-index is the strict validator).
read_records() {
  local dir="$1" file json
  [[ -d $dir ]] || return 0
  while IFS= read -r -d '' file; do
    json=$(jq -c . "$file" 2>/dev/null) || continue
    printf '%s\n' "$json" | jq -e '
      (.schema == "agent-outcome/v1")
      and (.id | type == "string")
      and (.issue | type == "number" and . > 0)
      and ((.status == "success") or (.status == "failure") or (.status == "blocked"))
      and (.started_at | type == "string")
      and (.finished_at | type == "string")
      and (.prs | type == "array")
      and (.blocker | type == "string")
    ' >/dev/null 2>&1 || continue
    printf '%s\n' "$json"
  done < <(find "$dir" -maxdepth 1 -type f -name '*.json' -print0 | sort -z)
}

# Sort the ndjson on stdin by (started_at, id) and re-emit one object per line,
# giving a stable, chronological ordering independent of filesystem order.
sort_records() {
  jq -s -c 'sort_by(.started_at, .id) | .[]'
}

# Render the Markdown dashboard from a file of sorted ndjson records ($1).
render_dashboard() {
  local records_file="$1"
  local count
  count=$(grep -c '' "$records_file" 2>/dev/null || true)
  count=${count:-0}

  echo "# Agent Outcome Dashboard"
  echo
  echo "Generated from ${count} committed outcome record(s) in chronological order (by started_at, id)."
  echo "Presentation only: no live infrastructure, no new telemetry."
  echo

  # --- Per-run table -------------------------------------------------------
  echo "## Runs"
  echo
  echo "| started_at | issue | status | cost_usd | turns | duration | risk |"
  echo "| --- | --- | --- | --- | --- | --- | --- |"
  if [[ $count -gt 0 ]]; then
    jq -rs '
      .[]
      | (.session // null) as $s
      | (
          if (.finished_at | type == "string") and (.started_at | type == "string")
          then (
            ((.finished_at | fromdateiso8601) - (.started_at | fromdateiso8601))
          )
          else null end
        ) as $dur
      | "| \(.started_at) "
        + "| #\(.issue) "
        + "| \(.status) "
        + "| \(if $s and ($s.cost_usd != null) then ($s.cost_usd | tostring) else "—" end) "
        + "| \(if $s and ($s.turns != null) then ($s.turns | tostring) else "—" end) "
        + "| \(if $dur != null then ("\($dur)s") else "—" end) "
        + "| \(.route.risk // "—") |"
    ' "$records_file"
  else
    echo "| (none) | | | | | | |"
  fi
  echo

  # --- Aggregate totals ----------------------------------------------------
  echo "## Aggregate totals"
  echo
  if [[ $count -gt 0 ]]; then
    jq -rs '
      {
        runs: length,
        success: ([.[] | select(.status == "success")] | length),
        failure: ([.[] | select(.status == "failure")] | length),
        blocked: ([.[] | select(.status == "blocked")] | length),
        cost_runs: ([.[] | select((.session.cost_usd // null) != null)] | length),
        total_cost: ([.[] | (.session.cost_usd // 0)] | add // 0),
        total_turns: ([.[] | (.session.turns // 0)] | add // 0),
        total_dur: ([.[]
          | select((.started_at | type == "string") and (.finished_at | type == "string"))
          | ((.finished_at | fromdateiso8601) - (.started_at | fromdateiso8601))] | add // 0)
      }
      | (if .cost_runs > 0 then (.total_cost / .cost_runs) else 0 end) as $avg_cost
      | "- Runs: \(.runs) (success \(.success), failure \(.failure), blocked \(.blocked))",
        "- Total cost_usd: \(.total_cost) (across \(.cost_runs) run(s) with session cost; avg \($avg_cost))",
        "- Total turns: \(.total_turns)",
        "- Total duration: \(.total_dur)s"
    ' "$records_file"
  else
    echo "- Runs: 0"
  fi
  echo

  # --- Cost / turns trend --------------------------------------------------
  echo "## Cost / turns trend"
  echo
  echo "| started_at | issue | cost_usd | turns |"
  echo "| --- | --- | --- | --- |"
  if [[ $count -gt 0 ]]; then
    jq -rs '
      .[]
      | (.session // null) as $s
      | "| \(.started_at) "
        + "| #\(.issue) "
        + "| \(if $s and ($s.cost_usd != null) then ($s.cost_usd | tostring) else "—" end) "
        + "| \(if $s and ($s.turns != null) then ($s.turns | tostring) else "—" end) |"
    ' "$records_file"
  else
    echo "| (none) | | | |"
  fi
  echo

  # --- Failure blockers ----------------------------------------------------
  echo "## Failure blockers"
  echo
  if [[ $count -gt 0 ]] && jq -se '[.[] | select(.status == "failure")] | length > 0' "$records_file" >/dev/null 2>&1; then
    jq -rs '
      [.[] | select(.status == "failure") | {issue, blocker}]
      | group_by(.blocker)
      | map({blocker: .[0].blocker, issues: (map(.issue) | unique | sort)})
      | sort_by(.blocker)
      | .[]
      | "- \(.issues | map("#" + (tostring)) | join(", ")): \(if (.blocker | length) > 0 then .blocker else "(no blocker recorded)" end)"
    ' "$records_file"
  else
    echo "- (none)"
  fi
}

# Build the full report from outcome dir $1 into stdout.
build_report() {
  local dir="$1"
  local records
  records=$(mktemp)
  # shellcheck disable=SC2064
  trap "rm -f '$records'" RETURN
  read_records "$dir" | sort_records >"$records"
  render_dashboard "$records"
}

self_test() {
  local tmp dir out
  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' RETURN
  dir="$tmp/outcomes"
  mkdir -p "$dir"

  # Success run with full session telemetry and a route risk.
  jq -n '{
    schema: "agent-outcome/v1", id: "2026-06-01T00:05:00Z-issue-101-success",
    issue: 101, status: "success", exit_code: 0,
    started_at: "2026-06-01T00:00:00Z", finished_at: "2026-06-01T00:05:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "codex/issue-101-foo",
    head_sha: "aaa111",
    prs: [], learning_candidates: [], git_dirty: [], blocker: "",
    session: {log: "s1.log", cost_usd: 1.25, turns: 12, duration_ms: 300000, id: "sess-1"},
    route: {schema: "agent-route/v1", path_classes: [], risk: "low", route: "auto"}
  }' >"$dir/2026-06-01T00:05:00Z-issue-101-success.json"

  # Failure run with session telemetry and a blocker reason.
  jq -n '{
    schema: "agent-outcome/v1", id: "2026-06-03T00:10:00Z-issue-102-failure",
    issue: 102, status: "failure", exit_code: 1,
    started_at: "2026-06-03T00:00:00Z", finished_at: "2026-06-03T00:10:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "codex/issue-102-bar",
    head_sha: "bbb222",
    prs: [], learning_candidates: [], git_dirty: [], blocker: "build failed: nix flake check",
    session: {log: "s2.log", cost_usd: 0.75, turns: 4, duration_ms: 600000, id: "sess-2"},
    route: {schema: "agent-route/v1", path_classes: [], risk: "medium", route: "human-review"}
  }' >"$dir/2026-06-03T00:10:00Z-issue-102-failure.json"

  # Blocked run with NO session object (must not crash; "—" in telemetry cols).
  jq -n '{
    schema: "agent-outcome/v1", id: "2026-06-02T00:01:00Z-issue-103-blocked",
    issue: 103, status: "blocked", exit_code: 1,
    started_at: "2026-06-02T00:00:00Z", finished_at: "2026-06-02T00:01:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "main",
    head_sha: "ccc333",
    prs: [], learning_candidates: [], git_dirty: [],
    blocker: "pre-dispatch readiness check failed"
  }' >"$dir/2026-06-02T00:01:00Z-issue-103-blocked.json"

  # Second failure sharing the same blocker as #102 (groups together).
  jq -n '{
    schema: "agent-outcome/v1", id: "2026-06-04T00:10:00Z-issue-104-failure",
    issue: 104, status: "failure", exit_code: 1,
    started_at: "2026-06-04T00:00:00Z", finished_at: "2026-06-04T00:10:00Z",
    base_branch: "main", repo_dir: "/repo", head_branch: "codex/issue-104-baz",
    head_sha: "ddd444",
    prs: [], learning_candidates: [], git_dirty: [], blocker: "build failed: nix flake check",
    session: {log: "s4.log", cost_usd: 0.50, turns: 2, duration_ms: 600000, id: "sess-4"}
  }' >"$dir/2026-06-04T00:10:00Z-issue-104-failure.json"

  # Malformed file: must be skipped, not crash.
  printf 'not json\n' >"$dir/2026-06-05T00:00:00Z-issue-105-failure.json"

  local records="$tmp/records.ndjson"
  read_records "$dir" | sort_records >"$records"
  [[ $(grep -c '' "$records") -eq 4 ]] || die "self-test: expected 4 valid records (got $(grep -c '' "$records"))"

  # Records must be sorted by started_at: #101, #103, #102, #104.
  local order
  order=$(jq -rs 'map(.issue) | join(",")' "$records")
  [[ $order == "101,103,102,104" ]] || die "self-test: expected chronological order 101,103,102,104 (got $order)"

  out=$(render_dashboard "$records")

  # Per-run table: success row carries cost/turns/duration/risk.
  [[ $out == *"| #101 | success | 1.25 | 12 | 300s | low |"* ]] ||
    die "self-test: expected per-run row for #101 (got: $out)"
  # Blocked run with no session shows em dashes for telemetry.
  [[ $out == *"| #103 | blocked | — | — | 60s | — |"* ]] ||
    die "self-test: expected em-dash telemetry row for #103 (got: $out)"

  # Aggregate totals.
  [[ $out == *"Runs: 4 (success 1, failure 2, blocked 1)"* ]] ||
    die "self-test: expected aggregate run mix (got: $out)"
  [[ $out == *"Total cost_usd: 2.5 (across 3 run(s) with session cost; avg 0.8333333333333334)"* ]] ||
    die "self-test: expected aggregate cost totals (got: $out)"
  [[ $out == *"Total turns: 18"* ]] ||
    die "self-test: expected total turns 18 (got: $out)"
  [[ $out == *"Total duration: 1560s"* ]] ||
    die "self-test: expected total duration 1560s (got: $out)"

  # Cost/turns trend section present with a known row.
  [[ $out == *"## Cost / turns trend"* ]] ||
    die "self-test: expected cost/turns trend section"
  [[ $out == *"| 2026-06-01T00:00:00Z | #101 | 1.25 | 12 |"* ]] ||
    die "self-test: expected trend row for #101 (got: $out)"

  # Failure blockers grouped: #102 and #104 share one blocker line.
  [[ $out == *"- #102, #104: build failed: nix flake check"* ]] ||
    die "self-test: expected grouped failure blockers for #102/#104 (got: $out)"

  # Determinism: a second render of the same input is byte-identical.
  local out2
  out2=$(render_dashboard "$records")
  [[ $out == "$out2" ]] || die "self-test: render is not deterministic"

  # Empty directory: must render the header without crashing.
  local empty="$tmp/empty"
  mkdir -p "$empty"
  local erecords="$tmp/empty.ndjson"
  read_records "$empty" | sort_records >"$erecords"
  out=$(render_dashboard "$erecords")
  [[ $out == *"# Agent Outcome Dashboard"* ]] || die "self-test: empty dir should still render header"
  [[ $out == *"Runs: 0"* ]] || die "self-test: empty dir should report 0 runs"

  printf 'agent-outcome-dashboard self-test passed\n'
}

main() {
  local dir="${AGENT_OUTCOME_DIR:-.agents/state/outcomes}"
  local out=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --dir)
      dir="${2:?--dir needs a value}"
      shift 2
      ;;
    --out)
      out="${2:?--out needs a value}"
      shift 2
      ;;
    --self-test)
      self_test
      exit 0
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
    esac
  done

  command -v jq >/dev/null 2>&1 || die "jq not found"

  if [[ -n $out ]]; then
    build_report "$dir" >"$out"
  else
    build_report "$dir"
  fi
}

main "$@"
